{
  "expo": {
    "name": "Kubsy",
    "slug": "kubsy_dating_app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "kubsy",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kubsy.app"
    },
    "android": {
      "package": "com.kubsy.app",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logo.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "enableProguardInReleaseBuilds": true,
            "enableMinifyInReleaseBuilds": true,
            "buildArchs": ["armeabi-v7a", "arm64-v8a"]
          }
        }
      ],
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#000000",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/logo.png",
          "color": "#ffffff"
        }
      ],
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.kubsy.datting",
          "enableGooglePay": false
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Kubsy to use your location.",
          "locationWhenInUsePermission": "Allow Kubsy to use your location."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Kubsy to access your photos.",
          "cameraPermission": "Allow Kubsy to access your camera."
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d90f7537-f704-49b5-8d10-df68521b415a"
      }
    },
    "experiments": {
      "typedRoutes": true
    },
    "owner": "salmarts"
  }
}
